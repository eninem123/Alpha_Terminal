function decodeTencentQuoteBody(buffer) {
  const labels = ["gbk", "gb18030"];
  for (let i = 0; i < labels.length; i++) {
    try {
      return new TextDecoder(labels[i]).decode(buffer);
    } catch {}
  }
  try {
