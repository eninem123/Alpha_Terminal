      return true;
    }
    const now = Date.now();
    const key = getClientKey(req);
    const guard = _adminLoginGuard.get(key) || { attempts: 0, lockUntil: 0 };
    if (guard.lockUntil && now < guard.lockUntil) {
      json(res, 429, { error: "尝试次数过多，请稍后再试。" });
