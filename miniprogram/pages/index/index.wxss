.page {
  min-height: 100vh;
  padding: 48rpx 40rpx 64rpx;
  background: #0f172a;
  box-sizing: border-box;
}

.hero {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #f1f5f9;
  line-height: 1.4;
}

.subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #94a3b8;
  line-height: 1.6;
}

.card {
  background: #1e293b;
  border: 1rpx solid #334155;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #e2e8f0;
  margin-bottom: 16rpx;
}

.card-text {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.8;
}

.disclaimer {
  margin: 32rpx 0 48rpx;
  padding: 24rpx;
  background: rgba(59, 130, 246, 0.08);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 16rpx;
}

.disclaimer text {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.8;
}

.enter-btn {
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: none;
}

.enter-btn::after {
  border: none;
}
